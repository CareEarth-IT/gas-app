{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "sync:admin": "tsx scripts/sync-admin-firestore-rules.ts",
    "deploy:firestore": "npm run sync:admin && firebase deploy --only firestore --project ce-gr-drive-2605st",
    "deploy:hosting": "npm run build && firebase deploy --only hosting --project ce-gr-drive-2605st",
    "deploy:firebase": "firebase deploy --only firestore,hosting --project ce-gr-drive-2605st",
    "deploy:production": "powershell -ExecutionPolicy Bypass -File scripts/deploy-production.ps1",
    "deploy:cloudrun": "gcloud run deploy gas-app --source . --region asia-northeast1 --project ce-gr-drive-2605st --allow-unauthenticated --no-invoker-iam-check --service-account firebase-adminsdk-fbsvc@ce-gr-drive-2605st.iam.gserviceaccount.com --update-env-vars NODE_ENV=production --quiet",
    "setup:cloudrun": "powershell -ExecutionPolicy Bypass -File scripts/setup-cloudrun.ps1",
    "setup:missing-report-reminder": "powershell -ExecutionPolicy Bypass -File scripts/setup-missing-report-reminder.ps1"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
