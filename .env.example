# ローカル開発用 .env（.env.example をコピーして使う）
#   Copy-Item .env.example .env

# =============================================================================
# Firebase Admin（管理画面 API のトークン検証）— いずれか1つを選ぶ
# =============================================================================

# 【推奨】秘密鍵 JSON が組織ポリシーで禁止されている場合
# 1) 下を有効化
LOCAL_FIREBASE_ADC=true
# 2) ターミナルで実行（Google アカウントでログイン）
#    gcloud auth application-default login --project ce-gr-drive-2605st
# 3) npm run dev を再起動

# 【代替】ローカルは画面だけ・API は本番 Cloud Run を使う（秘密鍵不要）
# VITE_API_BASE_URL="https://gas-app-231655548437.asia-northeast1.run.app"

# 【従来】サービスアカウント JSON がダウンロードできる場合のみ
# GOOGLE_APPLICATION_CREDENTIALS="C:\xampp\htdocs\gas-app\secrets\firebase-adminsdk.json"

# =============================================================================

# APP_URL: Production URL (Firebase Hosting).
APP_URL="https://drive.careearth.net"

# =============================================================================
# メール送信 — 本番はさくら（Cloud Run 環境変数 / scripts/setup-sakura-mail-cloudrun.ps1）
# =============================================================================
# MAIL_PROVIDER=sakura   … 既定（未設定でも sakura）。本番 Cloud Run はこちら。
# SAKURA_MAIL_SECRET=send-mail.php の $API_SECRET と同じ値
# SAKURA_MAIL_URL=https://violetgoat8.sakura.ne.jp/employee.drive/send-mail.php

# =============================================================================
# メール送信 — Firebase Mail（ローカル検証のみ・本番には設定しない）
# =============================================================================
# 1) Firebase Console → Extensions → 「Trigger Email (firestore-send-email)」をインストール
# 2) 自社ドメイン送信時は careearth.net の SPF TXT に include:_spf.firebasemail.com を追加
# 3) ローカル .env のみ:
# MAIL_PROVIDER=firebase
# FIREBASE_MAIL_COLLECTION=mail
# FIREBASE_MAIL_FROM=employee.drive@careearth.net

# =============================================================================
# Employee site -> Drive スタッフ同期（Cloud Run サーバー間）
# =============================================================================
# drive Cloud Run (gas-app) と employee Cloud Run で同じ値を設定:
# EMPLOYEE_SITE_SYNC_SECRET=共有秘密鍵
# scripts/setup-employee-site-sync-cloudrun.ps1
#
# employee 側から POST:
#   /api/integrations/employee-site/staff-profiles
# Header: X-Employee-Site-Secret: <secret>
# Body (1件):
#   { "email", "name", "employmentType": "employee"|"part_time", "departmentName" }
# Body (複数):
#   { "staff": [ ... ] }
# 部署一覧: GET /api/integrations/employee-site/departments

# =============================================================================
# 定時ジョブ（Cloud Scheduler → Cloud Run）
# =============================================================================
# 毎日 13:00 / 18:00 JST に運転報告未提出リマインド:
#   npm run setup:missing-report-reminder
# CRON_JOB_SECRET=（setup スクリプトが Cloud Run に設定）
# Endpoint: POST /api/jobs/remind-missing-reports
# Header: X-Job-Secret: <CRON_JOB_SECRET>

# 管理者メールは shared/adminEmails.ts で設定してください
